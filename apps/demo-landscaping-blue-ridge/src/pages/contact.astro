---
import ContactInfoSection from '@supernova/ui-sections/ContactInfoSection.astro';
import BusinessHoursSection from '@supernova/ui-sections/BusinessHoursSection.astro';
import CtaBannerSection from '@supernova/ui-sections/CtaBannerSection.astro';

import LandscapingLayout from '../layouts/LandscapingLayout.astro';
import { site } from '../site';

const quoteCta = site.ctas.find((cta) => cta.buttonHref === '/quote') ?? site.ctas[0];
---

<LandscapingLayout
  title="Contact"
  description={`Placeholder contact details for the ${site.business.displayName} demonstration business.`}
  path="/contact"
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Contact' },
  ]}
>
  <ContactInfoSection
    heading="Contact our demonstration studio"
    intro="Phone, email, and address fields are fictional placeholders."
    contact={site.contact}
  />

  <BusinessHoursSection
    heading="Business hours"
    intro="Hours illustrate schedule rendering only."
    hours={site.hours}
  />

  {
    quoteCta ? (
      <CtaBannerSection
        headline={quoteCta.headline}
        body={quoteCta.body}
        buttonLabel={quoteCta.buttonLabel}
        buttonHref={quoteCta.buttonHref}
      />
    ) : null
  }
</LandscapingLayout>