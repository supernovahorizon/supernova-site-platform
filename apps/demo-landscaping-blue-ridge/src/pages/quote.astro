---
import QuoteRequestFormSection from '@supernova/ui-sections/QuoteRequestFormSection.astro';

import LandscapingLayout from '../layouts/LandscapingLayout.astro';
import { site } from '../site';
---

<LandscapingLayout
  title="Plan your project"
  description={`Start a project inquiry with ${site.business.displayName}. Share site conditions, scope, and timing for your outdoor transformation.`}
  path="/quote"
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Quote' },
  ]}
>
  <QuoteRequestFormSection
    heading="Plan your project"
    intro="Describe your outdoor transformation goals. This sample form validates locally in the demo environment."
    submitLabel={site.leadForm.submitLabel}
    successMessage={site.leadForm.successMessage}
    privacyPolicyHref={site.leadForm.privacyPolicyHref}
    services={site.leadForm.services}
    budgetRanges={site.leadForm.budgetRanges}
  />
</LandscapingLayout>