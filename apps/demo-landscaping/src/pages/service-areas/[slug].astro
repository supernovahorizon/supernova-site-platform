---
import Container from '@supernova/ui-primitives/Container.astro';
import Section from '@supernova/ui-primitives/Section.astro';
import Heading from '@supernova/ui-primitives/Heading.astro';
import { createBreadcrumbJsonLd } from '@supernova/structured-data';
import CtaBannerSection from '@supernova/ui-sections/CtaBannerSection.astro';

import LandscapingLayout from '../../layouts/LandscapingLayout.astro';
import { site } from '../../site';

export function getStaticPaths() {
  return site.serviceAreas.map((area) => ({
    params: { slug: area.slug },
    props: { area },
  }));
}

const { area } = Astro.props;
const featuredServices = site.services.filter((service) =>
  area.featuredServices.includes(service.slug),
);
const quoteCta = site.ctas.find((cta) => cta.buttonHref === '/quote') ?? site.ctas[0];

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Service areas', href: '/service-areas' },
  { label: area.name },
];

const jsonLd = createBreadcrumbJsonLd(site.siteUrl, [
  { name: 'Home', path: '/' },
  { name: 'Service areas', path: '/service-areas' },
  { name: area.name, path: `/service-areas/${area.slug}` },
]);
---

<LandscapingLayout
  title={area.name}
  description={area.summary}
  path={`/service-areas/${area.slug}`}
  breadcrumbs={breadcrumbs}
  jsonLd={jsonLd}
>
  <Section ariaLabel={area.name}>
    <Container>
      <div class="area-detail">
        <div class="area-detail__content">
          <p class="area-detail__region">{area.regionLabel}</p>
          <Heading level={1}>{area.name}</Heading>
          <p class="area-detail__summary">{area.summary}</p>
          <p>{area.localIntroduction}</p>
          <Heading level={2}>Neighborhoods</Heading>
          <ul>
            {area.neighborhoods.map((neighborhood) => <li>{neighborhood}</li>)}
          </ul>
          <Heading level={2}>Featured services</Heading>
          <ul>
            {
              featuredServices.map((service) => (
                <li>
                  <a href={`/services/${service.slug}`}>{service.name}</a>
                </li>
              ))
            }
          </ul>
        </div>
        <figure class="area-detail__figure">
          <img src={area.heroImage.src} alt={area.heroImage.alt} loading="lazy" />
        </figure>
      </div>
    </Container>
  </Section>

  {
    quoteCta ? (
      <CtaBannerSection
        headline={quoteCta.headline}
        body={quoteCta.body}
        buttonLabel={quoteCta.buttonLabel}
        buttonHref={quoteCta.buttonHref}
      />
    ) : null
  }
</LandscapingLayout>

<style>
  .area-detail {
    display: grid;
    gap: var(--sn-space-lg, 1.5rem);
    background: var(--sn-color-surface, #ffffff);
    border: 1px solid var(--sn-color-border, #d9e2ec);
    border-radius: var(--sn-radius-lg, 1rem);
    padding: var(--sn-space-xl, 2.5rem);
  }

  @media (min-width: 48rem) {
    .area-detail {
      grid-template-columns: 1.2fr 0.8fr;
      align-items: start;
    }
  }

  .area-detail__region {
    margin: 0 0 0.5rem;
    font-weight: 600;
    color: var(--sn-color-accent, #2f6f4e);
  }

  .area-detail__summary {
    font-size: 1.125rem;
    font-weight: 600;
  }

  .area-detail__figure {
    margin: 0;
  }

  .area-detail__figure img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--sn-radius-md, 0.5rem);
  }
</style>