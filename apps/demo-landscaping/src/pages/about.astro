---
import Container from '@supernova/ui-primitives/Container.astro';
import Section from '@supernova/ui-primitives/Section.astro';
import Heading from '@supernova/ui-primitives/Heading.astro';
import CtaBannerSection from '@supernova/ui-sections/CtaBannerSection.astro';

import LandscapingLayout from '../layouts/LandscapingLayout.astro';
import { site } from '../site';

const contactCta = site.ctas.find((cta) => cta.buttonHref === '/contact') ?? site.ctas[1];
---

<LandscapingLayout
  title={site.about.title}
  description={site.about.introduction}
  path="/about"
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: site.about.title },
  ]}
>
  <Section ariaLabel={site.about.title}>
    <Container>
      <article class="about-page">
        <Heading level={1}>{site.about.title}</Heading>
        <p>{site.about.introduction}</p>
        <Heading level={2}>Values</Heading>
        <ul>
          {site.about.values.map((value) => <li>{value}</li>)}
        </ul>
      </article>
    </Container>
  </Section>

  {
    contactCta ? (
      <CtaBannerSection
        headline={contactCta.headline}
        body={contactCta.body}
        buttonLabel={contactCta.buttonLabel}
        buttonHref={contactCta.buttonHref}
      />
    ) : null
  }
</LandscapingLayout>

<style>
  .about-page {
    background: var(--sn-color-surface, #ffffff);
    border: 1px solid var(--sn-color-border, #d9e2ec);
    border-radius: var(--sn-radius-lg, 1rem);
    padding: var(--sn-space-xl, 2.5rem);
    max-width: 70ch;
  }
</style>