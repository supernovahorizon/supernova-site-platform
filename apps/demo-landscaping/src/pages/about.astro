---
import Container from '@supernova/ui-primitives/Container.astro';
import Section from '@supernova/ui-primitives/Section.astro';
import Heading from '@supernova/ui-primitives/Heading.astro';
import CtaBannerSection from '@supernova/ui-sections/CtaBannerSection.astro';

import LandscapingLayout from '../layouts/LandscapingLayout.astro';
import { site } from '../site';

const contactCta = site.ctas.find((cta) => cta.buttonHref === '/contact') ?? site.ctas[1];
---

<LandscapingLayout
  title={site.about.title}
  description={site.about.introduction}
  path="/about"
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: site.about.title },
  ]}
>
  <Section ariaLabel={site.about.title}>
    <Container>
      <div class="about-grid">
        <header class="about-header">
          <Heading level={1}>{site.about.title}</Heading>
          <p class="about-intro">{site.about.introduction}</p>
        </header>

        <div class="about-values">
          <Heading level={2} class="values-heading">Our Core Values</Heading>
          <div class="values-grid">
            {
              site.about.values.map((value, idx) => (
                <div class="value-card">
                  <span class="value-number">0{idx + 1}</span>
                  <p class="value-text">{value}</p>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </Container>
  </Section>

  {
    contactCta ? (
      <CtaBannerSection
        headline={contactCta.headline}
        body={contactCta.body}
        buttonLabel={contactCta.buttonLabel}
        buttonHref={contactCta.buttonHref}
      />
    ) : null
  }
</LandscapingLayout>

<style>
  .about-grid {
    display: grid;
    gap: clamp(2rem, 6vw, 4rem);
  }

  @media (min-width: 48rem) {
    .about-grid {
      grid-template-columns: 1.15fr 0.85fr;
      align-items: start;
    }
  }

  .about-header {
    display: grid;
    gap: var(--sn-space-md, 1rem);
  }

  .about-intro {
    font-size: 1.25rem;
    line-height: 1.7;
    color: var(--sn-color-text-muted);
    text-wrap: pretty;
  }

  .about-values {
    display: grid;
    gap: var(--sn-space-lg, 1.5rem);
  }

  .values-heading {
    margin-bottom: 0.5rem;
  }

  .values-grid {
    display: grid;
    gap: var(--sn-space-md, 1rem);
  }

  .value-card {
    background: var(--sn-color-surface, #ffffff);
    border: 1px solid var(--sn-color-border, #d9e2ec);
    border-radius: var(--sn-radius-lg, 1rem);
    padding: var(--sn-space-lg, 1.5rem);
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    box-shadow: var(--sn-shadow-sm);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s ease, border-color 0.3s ease;
  }

  .value-card:hover {
    transform: translateX(6px);
    border-color: var(--sn-color-accent);
    box-shadow: var(--sn-shadow-md);
  }

  .value-number {
    font-family: var(--sn-font-display, Georgia, serif);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--sn-color-accent);
    line-height: 1;
  }

  .value-text {
    margin: 0;
    font-weight: 600;
    line-height: 1.45;
    font-size: 1.0625rem;
  }
</style>