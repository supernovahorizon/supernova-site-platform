---
import QuoteRequestFormSection from '@supernova/ui-sections/QuoteRequestFormSection.astro';

import LandscapingLayout from '../layouts/LandscapingLayout.astro';
import { site } from '../site';
---

<LandscapingLayout
  title="Request a quote"
  description={`Request a free landscaping estimate from ${site.business.displayName}. Share your project details and we will follow up with next steps.`}
  path="/quote"
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Quote' },
  ]}
>
  <QuoteRequestFormSection
    heading="Request a free estimate"
    intro="Tell us about your property and project goals. This sample form validates your request locally in the demo environment."
    submitLabel={site.leadForm.submitLabel}
    successMessage={site.leadForm.successMessage}
    privacyPolicyHref={site.leadForm.privacyPolicyHref}
    services={site.leadForm.services}
    budgetRanges={site.leadForm.budgetRanges}
  />
</LandscapingLayout>