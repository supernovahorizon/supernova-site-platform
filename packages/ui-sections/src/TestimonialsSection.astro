---
import Container from '@supernova/ui-primitives/Container.astro';
import Section from '@supernova/ui-primitives/Section.astro';
import Heading from '@supernova/ui-primitives/Heading.astro';
import type { TestimonialsSectionProps } from './component-props';
import {
  DEFAULT_FICTIONAL_DEMONSTRATION_LABEL,
  getFictionalDemonstrationLabel,
  requiresFictionalDemonstrationLabel,
} from './props';

interface Props extends TestimonialsSectionProps {}

const {
  heading,
  intro,
  testimonials,
  fictionalDemonstrationLabel = DEFAULT_FICTIONAL_DEMONSTRATION_LABEL,
  class: className = '',
} = Astro.props;

const showSectionLabel = requiresFictionalDemonstrationLabel(testimonials);
---

<Section class={`sn-sec-testimonials ${className}`.trim()} ariaLabel={heading}>
  <Container>
    <div class="sn-sec-testimonials__header">
      <Heading level={2}>{heading}</Heading>
      {intro ? <p class="sn-sec__intro">{intro}</p> : null}
      {
        showSectionLabel ? (
          <p class="sn-sec-testimonials__section-label" role="note">
            {fictionalDemonstrationLabel}
          </p>
        ) : null
      }
    </div>

    <div class="sn-sec-testimonials__grid">
      {
        testimonials.map((testimonial) => {
          const itemLabel = getFictionalDemonstrationLabel(
            testimonial.isFictionalDemonstration,
            fictionalDemonstrationLabel,
          );
          const initial = testimonial.authorName.trim().charAt(0).toUpperCase();

          return (
            <figure class="sn-sec-testimonials__item" id={`testimonial-${testimonial.id}`}>
              {itemLabel ? <span class="sn-sec-testimonials__badge">{itemLabel}</span> : null}
              <blockquote cite={`#testimonial-${testimonial.id}`}>
                <p>“{testimonial.quote}”</p>
              </blockquote>
              <figcaption class="sn-sec-testimonials__author">
                <span class="sn-sec-testimonials__avatar" aria-hidden="true">
                  {initial}
                </span>
                <span>
                  <strong>{testimonial.authorName}</strong>
                  <span class="sn-sec-testimonials__context">{testimonial.authorContext}</span>
                </span>
              </figcaption>
            </figure>
          );
        })
      }
    </div>
  </Container>
</Section>

<style>
  .sn-sec-testimonials__header {
    margin-bottom: var(--sn-space-lg, 1.5rem);
  }

  .sn-sec-testimonials__section-label {
    display: inline-flex;
    margin: 0.75rem 0 0;
    padding: 0.25rem 0.65rem;
    border-radius: var(--sn-radius-pill, 999px);
    background: color-mix(in srgb, var(--sn-color-accent, #c46b4a) 12%, transparent);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--sn-color-text-muted, inherit);
  }

  .sn-sec-testimonials__grid {
    display: grid;
    gap: var(--sn-space-md, 1rem);
  }

  @media (min-width: 40rem) {
    .sn-sec-testimonials__grid {
      grid-template-columns: repeat(auto-fit, minmax(17rem, 1fr));
    }
  }

  .sn-sec-testimonials__item {
    margin: 0;
    padding: var(--sn-space-lg, 2rem);
    background: var(--sn-color-surface, #fff);
    border: 1px solid var(--sn-color-border, #d9e2ec);
    border-radius: var(--sn-radius-xl, 1.75rem);
    box-shadow: var(--sn-shadow-md);
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s ease;
  }

  .sn-sec-testimonials__item:hover {
    transform: translateY(-4px);
    box-shadow: var(--sn-shadow-lg);
  }

  .sn-sec-testimonials__badge {
    align-self: start;
    display: inline-flex;
    margin-bottom: 1rem;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--sn-color-accent, #c46b4a);
    background: color-mix(in srgb, var(--sn-color-accent, #c46b4a) 8%, transparent);
    padding: 0.25rem 0.65rem;
    border-radius: var(--sn-radius-pill, 999px);
  }

  .sn-sec-testimonials__item blockquote {
    margin: 0 0 var(--sn-space-lg, 1.5rem);
    font-family: var(--sn-font-display, inherit);
    font-size: 1.125rem;
    line-height: 1.6;
    position: relative;
    z-index: 1;
  }

  .sn-sec-testimonials__item blockquote::before {
    content: "“";
    font-family: var(--sn-font-display, Georgia, serif);
    font-size: 5.5rem;
    color: color-mix(in srgb, var(--sn-color-accent, #2f6f4e) 12%, transparent);
    position: absolute;
    top: -2.75rem;
    left: -1rem;
    z-index: -1;
    line-height: 1;
    pointer-events: none;
  }

  .sn-sec-testimonials__item blockquote p {
    margin: 0;
  }

  .sn-sec-testimonials__author {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin: 0;
    border-top: 1px solid var(--sn-color-border, #d9e2ec);
    padding-top: var(--sn-space-md, 1rem);
  }

  .sn-sec-testimonials__avatar {
    display: grid;
    place-items: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: var(--sn-radius-pill, 999px);
    background: linear-gradient(135deg, var(--sn-color-primary, #2f5d44) 0%, color-mix(in srgb, var(--sn-color-primary, #2f5d44) 65%, var(--sn-color-accent, #c46b4a)) 100%);
    color: var(--sn-color-accent-contrast, #ffffff);
    font-weight: 700;
    font-size: 1rem;
    box-shadow: var(--sn-shadow-sm);
  }

  .sn-sec-testimonials__author strong {
    display: block;
    color: var(--sn-color-text);
  }

  .sn-sec-testimonials__context {
    display: block;
    font-size: 0.875rem;
    color: var(--sn-color-text-muted, inherit);
  }
</style>