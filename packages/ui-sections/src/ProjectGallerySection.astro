---
import Container from '@supernova/ui-primitives/Container.astro';
import Section from '@supernova/ui-primitives/Section.astro';
import Heading from '@supernova/ui-primitives/Heading.astro';
import ResponsiveImage from './ResponsiveImage.astro';
import type { ProjectGallerySectionProps } from './component-props';
import { resolveProjectHref } from './props';

interface Props extends ProjectGallerySectionProps {}

const {
  heading,
  intro,
  projects,
  projectBasePath = '/projects',
  variant = 'editorial',
  class: className = '',
} = Astro.props;
---

<Section class={`sn-sec-gallery sn-sec-gallery--${variant} ${className}`.trim()} ariaLabel={heading}>
  <Container>
    <div class="sn-sec-gallery__header">
      <Heading level={2}>{heading}</Heading>
      {intro ? <p class="sn-sec__intro">{intro}</p> : null}
    </div>

    <div class="sn-sec-gallery__grid">
      {
        projects.map((project, index) => {
          const href = resolveProjectHref(project, projectBasePath);
          const featured = variant === 'editorial' && index === 0;

          return (
            <article class={`sn-sec-gallery__item${featured ? ' sn-sec-gallery__item--featured' : ''}`}>
              <a class="sn-sec-gallery__link" href={href}>
                <div class="sn-sec-gallery__media">
                  <ResponsiveImage
                    src={project.image.src}
                    alt={project.image.alt}
                    width={960}
                    height={featured ? 720 : 640}
                    sizes={featured ? '(min-width: 48rem) 66vw, 100vw' : '(min-width: 48rem) 33vw, 100vw'}
                  />
                </div>
                <div class="sn-sec-gallery__body">
                  <Heading level={3}>{project.title}</Heading>
                  <p>{project.summary}</p>
                  <p class="sn-sec-gallery__meta">{project.completedLabel}</p>
                </div>
              </a>
            </article>
          );
        })
      }
    </div>
  </Container>
</Section>

<style>
  .sn-sec-gallery__header {
    margin-bottom: var(--sn-space-xl, 2.5rem);
  }

  .sn-sec-gallery__grid {
    display: grid;
    gap: var(--sn-space-lg, 1.5rem);
  }

  .sn-sec-gallery--editorial .sn-sec-gallery__grid {
    grid-template-columns: 1fr;
  }

  @media (min-width: 48rem) {
    .sn-sec-gallery--editorial {
      padding-bottom: clamp(4rem, 10vw, 8rem);
    }

    .sn-sec-gallery--editorial .sn-sec-gallery__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 3rem 2rem;
    }

    .sn-sec-gallery--editorial .sn-sec-gallery__item:nth-child(even):not(.sn-sec-gallery__item--featured) {
      transform: translateY(3rem);
    }

    .sn-sec-gallery--editorial .sn-sec-gallery__item--featured {
      grid-column: span 2;
      display: grid;
      grid-template-columns: 1.15fr 0.85fr;
      align-items: center;
      gap: 0;
    }

    .sn-sec-gallery--editorial .sn-sec-gallery__item--featured .sn-sec-gallery__body {
      margin-inline-start: -3rem;
      background: var(--sn-color-surface, #fff);
      border-radius: var(--sn-radius-xl, 1.75rem);
      padding: var(--sn-space-xl, 2.5rem);
      box-shadow: var(--sn-shadow-md);
      border: 1px solid var(--sn-color-border);
      z-index: 5;
    }

    .sn-sec-gallery--grid .sn-sec-gallery__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
  }

  .sn-sec-gallery__item {
    overflow: hidden;
    background: var(--sn-color-surface, #fff);
    border: 1px solid var(--sn-color-border, #d9e2ec);
    border-radius: var(--sn-radius-xl, 1.75rem);
    box-shadow: var(--sn-shadow-sm, none);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s ease, border-color 0.3s ease;
  }

  .sn-sec-gallery__item:hover {
    box-shadow: var(--sn-shadow-md);
  }

  /* Grid specific slide-up styling */
  .sn-sec-gallery--grid .sn-sec-gallery__item {
    position: relative;
    border-radius: var(--sn-radius-md, 0.25rem);
    background: var(--sn-color-surface, #131a22);
    border-color: var(--sn-color-border, #202c3a);
  }

  .sn-sec-gallery--grid .sn-sec-gallery__media {
    aspect-ratio: 1 / 1;
    width: 100%;
  }

  .sn-sec-gallery--grid .sn-sec-gallery__body {
    position: absolute;
    inset: auto 0 0 0;
    background: linear-gradient(to top, rgba(11, 15, 19, 0.95) 0%, rgba(11, 15, 19, 0.7) 70%, transparent 100%);
    color: #e8edf2;
    padding: var(--sn-space-lg, 1.5rem);
    transform: translateY(30px);
    opacity: 0;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease;
    z-index: 2;
    pointer-events: none;
  }

  .sn-sec-gallery--grid .sn-sec-gallery__item:hover .sn-sec-gallery__body,
  .sn-sec-gallery--grid .sn-sec-gallery__item:focus-within .sn-sec-gallery__body {
    transform: translateY(0);
    opacity: 1;
  }

  .sn-sec-gallery--grid .sn-sec-gallery__item:hover {
    border-color: var(--sn-color-accent, #3a8ecf);
    transform: translateY(-4px);
  }

  .sn-sec-gallery--grid .sn-sec-gallery__body p {
    color: var(--sn-color-text-muted, #8b9ba8);
  }

  .sn-sec-gallery__link {
    display: grid;
    height: 100%;
    color: inherit;
    text-decoration: none;
  }

  .sn-sec-gallery__media {
    aspect-ratio: 16 / 11;
    overflow: hidden;
  }

  .sn-sec-gallery__media :global(img) {
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  @media (prefers-reduced-motion: no-preference) {
    .sn-sec-gallery__item:hover .sn-sec-gallery__media :global(img) {
      transform: scale(1.04);
    }
  }

  .sn-sec-gallery__body {
    padding: var(--sn-space-lg, 1.5rem);
  }

  .sn-sec-gallery__body p {
    margin: 0.5rem 0 0;
    color: var(--sn-color-text-muted, inherit);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .sn-sec-gallery__meta {
    margin-top: 0.75rem !important;
    font-size: 0.75rem !important;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--sn-color-accent, #2f6f4e) !important;
  }

  .sn-sec-gallery--grid .sn-sec-gallery__meta {
    color: var(--sn-color-accent, #3a8ecf) !important;
  }
</style>