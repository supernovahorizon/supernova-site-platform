---
import Container from '@supernova/ui-primitives/Container.astro';
import type { SiteHeaderProps } from './component-props';
import { normalizeNavigationItems } from './props';

interface Props extends SiteHeaderProps {}

const {
  logoSrc,
  logoAlt,
  displayName,
  homeHref = '/',
  navItems,
  quoteCta,
  phone,
  variant = 'editorial',
  currentPath = '/',
  class: className = '',
} = Astro.props;

const links = normalizeNavigationItems(navItems);
const navId = 'sn-site-nav';
const mobileNavId = 'sn-mobile-nav';
const menuButtonId = 'sn-menu-button';
---

<header class={`sn-sec-header sn-sec-header--${variant} ${className}`.trim()} data-site-header>
  <Container>
    <div class="sn-sec-header__inner">
      <a class="sn-sec-header__brand" href={homeHref}>
        <img class="sn-sec-header__logo" src={logoSrc} alt={logoAlt} width="200" height="56" />
        {displayName ? <span class="sn-sec-header__name">{displayName}</span> : null}
      </a>

      <nav class="sn-sec-header__nav" id={navId} aria-label="Primary">
        <ul class="sn-sec-header__nav-list">
          {
            links.map((item) => (
              <li>
                <a
                  class="sn-sec__nav-link"
                  href={item.href}
                  aria-current={currentPath === item.href ? 'page' : undefined}
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div class="sn-sec-header__actions">
        {
          phone ? (
            <a class="sn-sec-header__phone sn-btn sn-btn--ghost" href={`tel:${phone.replace(/\D/g, '')}`}>
              {phone}
            </a>
          ) : null
        }
        {
          quoteCta ? (
            <a class="sn-btn sn-btn--primary sn-sec-header__quote" href={quoteCta.href}>
              {quoteCta.label}
            </a>
          ) : null
        }
        <button
          type="button"
          class="sn-sec-header__menu-button"
          id={menuButtonId}
          aria-expanded="false"
          aria-controls={mobileNavId}
        >
          <span class="sn-sec-header__menu-icon" aria-hidden="true" />
          <span class="sn-sec-header__menu-label">Menu</span>
        </button>
      </div>
    </div>
  </Container>

  <div class="sn-sec-header__mobile-panel" id={mobileNavId} hidden>
    <nav aria-label="Mobile primary">
      <ul class="sn-sec-header__mobile-list">
        {
          links.map((item) => (
            <li>
              <a
                class="sn-sec-header__mobile-link"
                href={item.href}
                aria-current={currentPath === item.href ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
      {
        quoteCta ? (
          <a class="sn-btn sn-btn--primary sn-sec-header__mobile-quote" href={quoteCta.href}>
            {quoteCta.label}
          </a>
        ) : null
      }
    </nav>
  </div>
</header>

<div class="sn-sec-header__sticky-cta" data-sticky-cta hidden>
  {
    quoteCta ? (
      <a class="sn-btn sn-btn--primary" href={quoteCta.href}>
        {quoteCta.label}
      </a>
    ) : null
  }
</div>

<script>
  const header = document.querySelector('[data-site-header]');
  const menuButton = document.getElementById('sn-menu-button');
  const mobilePanel = document.getElementById('sn-mobile-nav');
  const stickyCta = document.querySelector('[data-sticky-cta]');

  if (header instanceof HTMLElement && menuButton instanceof HTMLButtonElement && mobilePanel instanceof HTMLElement) {
    let lastFocus: HTMLElement | null = null;

    const openMenu = () => {
      lastFocus = document.activeElement instanceof HTMLElement ? document.activeElement : null;
      mobilePanel.hidden = false;
      menuButton.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
      const firstLink = mobilePanel.querySelector('a');
      if (firstLink instanceof HTMLElement) firstLink.focus();
    };

    const closeMenu = () => {
      mobilePanel.hidden = true;
      menuButton.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
      if (lastFocus) lastFocus.focus();
    };

    menuButton.addEventListener('click', () => {
      if (mobilePanel.hidden) openMenu();
      else closeMenu();
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && !mobilePanel.hidden) {
        event.preventDefault();
        closeMenu();
      }
    });

    mobilePanel.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => closeMenu());
    });
  }

  if (header instanceof HTMLElement && stickyCta instanceof HTMLElement) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        stickyCta.hidden = entry?.isIntersecting ?? true;
      },
      { threshold: 0, rootMargin: '-4rem 0px 0px 0px' },
    );
    observer.observe(header);
  }
</script>

<style>
  .sn-sec-header {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid var(--sn-color-border, #d9e2ec);
    background: color-mix(in srgb, var(--sn-color-surface, #fff) 92%, transparent);
    backdrop-filter: blur(12px);
    padding-block: 0.75rem;
    padding-top: max(0.75rem, env(safe-area-inset-top));
  }

  .sn-sec-header--cinematic {
    background: color-mix(in srgb, var(--sn-color-surface, #1a2229) 94%, transparent);
  }

  .sn-sec-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sn-space-md, 1rem);
  }

  .sn-sec-header__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    min-width: 0;
  }

  .sn-sec-header__logo {
    display: block;
    height: auto;
    max-height: 2.75rem;
    width: auto;
    flex-shrink: 0;
  }

  .sn-sec-header__name {
    font-family: var(--sn-font-display, inherit);
    font-weight: 700;
    font-size: clamp(0.95rem, 2.5vw, 1.125rem);
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .sn-sec-header__nav-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sn-space-sm, 0.75rem) var(--sn-space-md, 1rem);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .sn-sec-header__actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .sn-sec-header__phone {
    display: none;
    font-size: 0.9375rem;
  }

  .sn-sec-header__quote {
    display: none;
  }

  .sn-sec-header__nav {
    display: none;
  }

  .sn-sec-header__menu-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    min-height: 2.75rem;
    min-width: 2.75rem;
    padding: 0.5rem 0.85rem;
    border: 1px solid var(--sn-color-border, #d9e2ec);
    border-radius: var(--sn-radius-md, 0.5rem);
    background: var(--sn-color-surface-elevated, var(--sn-color-surface, #fff));
    font: inherit;
    font-weight: 600;
    cursor: pointer;
  }

  .sn-sec-header__menu-icon {
    width: 1.125rem;
    height: 2px;
    background: currentColor;
    box-shadow:
      0 -6px 0 currentColor,
      0 6px 0 currentColor;
  }

  .sn-sec-header__mobile-panel {
    position: fixed;
    inset: 0;
    top: 0;
    z-index: 60;
    background: var(--sn-color-surface, #fff);
    padding: calc(4.5rem + env(safe-area-inset-top)) 1.25rem 2rem;
    overflow-y: auto;
  }

  .sn-sec-header__mobile-list {
    list-style: none;
    margin: 0 0 1.5rem;
    padding: 0;
    display: grid;
    gap: 0.25rem;
  }

  .sn-sec-header__mobile-link {
    display: flex;
    align-items: center;
    min-height: 2.75rem;
    padding: 0.65rem 0;
    font-size: 1.125rem;
    font-weight: 600;
    text-decoration: none;
    border-bottom: 1px solid var(--sn-color-border, #d9e2ec);
  }

  .sn-sec-header__mobile-quote {
    width: 100%;
  }

  .sn-sec-header__sticky-cta {
    position: fixed;
    left: 1rem;
    right: 1rem;
    bottom: calc(1rem + env(safe-area-inset-bottom));
    z-index: 40;
    box-shadow: var(--sn-shadow-lg, 0 8px 24px rgb(0 0 0 / 16%));
    display: flex;
    justify-content: center;
  }

  .sn-sec-header__sticky-cta .sn-btn {
    width: 100%;
    max-width: 22rem;
  }

  @media (min-width: 48rem) {
    .sn-sec-header__nav {
      display: block;
    }

    .sn-sec-header__menu-button {
      display: none;
    }

    .sn-sec-header__quote {
      display: inline-flex;
    }

    .sn-sec-header__phone {
      display: inline-flex;
    }

    .sn-sec-header__sticky-cta {
      display: none;
    }
  }
</style>