---
import Container from '@supernova/ui-primitives/Container.astro';
import type { SiteHeaderProps } from './component-props';
import { normalizeNavigationItems } from './props';

interface Props extends SiteHeaderProps {}

const {
  logoSrc,
  logoAlt,
  displayName,
  homeHref = '/',
  navItems,
  quoteCta,
  phone,
  variant = 'editorial',
  currentPath = '/',
  class: className = '',
} = Astro.props;

const links = normalizeNavigationItems(navItems);
const navId = 'sn-site-nav';
const mobileNavId = 'sn-mobile-nav';
const menuButtonId = 'sn-menu-button';
---

<header class={`sn-sec-header sn-sec-header--${variant} ${className}`.trim()} data-site-header>
  <Container>
    <div class="sn-sec-header__inner">
      <a class="sn-sec-header__brand" href={homeHref}>
        <img class="sn-sec-header__logo" src={logoSrc} alt={logoAlt} width="200" height="56" />
        {displayName ? <span class="sn-sec-header__name">{displayName}</span> : null}
      </a>

      <nav class="sn-sec-header__nav" id={navId} aria-label="Primary">
        <ul class="sn-sec-header__nav-list">
          {
            links.map((item) => (
              <li>
                <a
                  class="sn-sec__nav-link"
                  href={item.href}
                  aria-current={currentPath === item.href ? 'page' : undefined}
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div class="sn-sec-header__actions">
        {
          phone ? (
            <a class="sn-sec-header__phone sn-btn sn-btn--ghost" href={`tel:${phone.replace(/\D/g, '')}`}>
              {phone}
            </a>
          ) : null
        }
        {
          quoteCta ? (
            <a class="sn-btn sn-btn--primary sn-sec-header__quote" href={quoteCta.href}>
              {quoteCta.label}
            </a>
          ) : null
        }
        <button
          type="button"
          class="sn-sec-header__menu-button"
          id={menuButtonId}
          aria-expanded="false"
          aria-controls={mobileNavId}
        >
          <span class="sn-sec-header__menu-icon" aria-hidden="true" />
          <span class="sn-sec-header__menu-label">Menu</span>
        </button>
      </div>
    </div>
  </Container>

  <div class="sn-sec-header__mobile-panel" id={mobileNavId} hidden>
    <nav aria-label="Mobile primary">
      <ul class="sn-sec-header__mobile-list">
        {
          links.map((item) => (
            <li>
              <a
                class="sn-sec-header__mobile-link"
                href={item.href}
                aria-current={currentPath === item.href ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
      {
        quoteCta ? (
          <a class="sn-btn sn-btn--primary sn-sec-header__mobile-quote" href={quoteCta.href}>
            {quoteCta.label}
          </a>
        ) : null
      }
    </nav>
  </div>
</header>

<div class="sn-sec-header__sticky-cta" data-sticky-cta hidden>
  {
    quoteCta ? (
      <a class="sn-btn sn-btn--primary" href={quoteCta.href}>
        {quoteCta.label}
      </a>
    ) : null
  }
</div>

<script>
  const header = document.querySelector('[data-site-header]');
  const menuButton = document.getElementById('sn-menu-button');
  const mobilePanel = document.getElementById('sn-mobile-nav');
  const stickyCta = document.querySelector('[data-sticky-cta]');

  if (header instanceof HTMLElement && menuButton instanceof HTMLButtonElement && mobilePanel instanceof HTMLElement) {
    let lastFocus: HTMLElement | null = null;

    const openMenu = () => {
      lastFocus = document.activeElement instanceof HTMLElement ? document.activeElement : null;
      mobilePanel.hidden = false;
      // Trigger slide/fade transition
      requestAnimationFrame(() => {
        mobilePanel.classList.add('is-open');
      });
      menuButton.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
      const firstLink = mobilePanel.querySelector('a');
      if (firstLink instanceof HTMLElement) firstLink.focus();
    };

    const closeMenu = () => {
      mobilePanel.classList.remove('is-open');
      menuButton.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
      
      const onTransitionEnd = (e: TransitionEvent) => {
        if (e.propertyName === 'transform') {
          mobilePanel.hidden = true;
          mobilePanel.removeEventListener('transitionend', onTransitionEnd);
        }
      };
      mobilePanel.addEventListener('transitionend', onTransitionEnd);
      
      // Safety fallback
      setTimeout(() => {
        if (!mobilePanel.classList.contains('is-open')) {
          mobilePanel.hidden = true;
        }
      }, 350);

      if (lastFocus) lastFocus.focus();
    };

    menuButton.addEventListener('click', () => {
      if (mobilePanel.hidden || !mobilePanel.classList.contains('is-open')) openMenu();
      else closeMenu();
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && mobilePanel.classList.contains('is-open')) {
        event.preventDefault();
        closeMenu();
      }
    });

    mobilePanel.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => closeMenu());
    });
  }

  if (header instanceof HTMLElement && stickyCta instanceof HTMLElement) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        stickyCta.hidden = entry?.isIntersecting ?? true;
      },
      { threshold: 0, rootMargin: '-4rem 0px 0px 0px' },
    );
    observer.observe(header);
  }
</script>

<style>
  .sn-sec-header {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid var(--sn-color-border, #d9e2ec);
    background: color-mix(in srgb, var(--sn-color-surface, #fff) 85%, transparent);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    padding-block: 0.85rem;
    padding-top: max(0.85rem, env(safe-area-inset-top));
    transition: background 0.3s ease, border-color 0.3s ease;
  }

  .sn-sec-header--cinematic {
    background: color-mix(in srgb, var(--sn-color-surface, #1a2229) 88%, transparent);
  }

  .sn-sec-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sn-space-md, 1rem);
  }

  .sn-sec-header__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    min-width: 0;
    flex-shrink: 0;
  }

  .sn-sec-header__logo {
    display: block;
    height: auto;
    max-height: 2.85rem;
    width: auto;
    flex-shrink: 0;
  }

  .sn-sec-header__name {
    font-family: var(--sn-font-display, inherit);
    font-weight: 700;
    font-size: clamp(1.05rem, 2.5vw, 1.25rem);
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Nav Lists */
  .sn-sec-header__nav-list {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    gap: 0.5rem var(--sn-space-md, 1.25rem);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* Editorial Link Styles */
  .sn-sec-header--editorial .sn-sec__nav-link {
    font-family: var(--sn-font-heading, Georgia, serif);
    font-size: 1rem;
    font-weight: 600;
    position: relative;
    padding: 0.25rem 0.5rem;
    transition: color 0.25s ease;
    color: var(--sn-color-text-muted, #42564c);
    white-space: nowrap; /* Prevent multi-word wrapping */
  }

  .sn-sec-header--editorial .sn-sec__nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0.5rem;
    right: 0.5rem;
    height: 2px;
    background: var(--sn-color-accent, #c46b4a);
    transform: scaleX(0);
    transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .sn-sec-header--editorial .sn-sec__nav-link:hover::after,
  .sn-sec-header--editorial .sn-sec__nav-link[aria-current='page']::after {
    transform: scaleX(1);
  }

  .sn-sec-header--editorial .sn-sec__nav-link:hover,
  .sn-sec-header--editorial .sn-sec__nav-link[aria-current='page'] {
    color: var(--sn-color-text, #11241a);
    text-decoration: none;
  }

  /* Cinematic Link Styles */
  .sn-sec-header--cinematic .sn-sec__nav-link {
    font-family: var(--sn-font-body, system-ui, sans-serif);
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.5rem 1rem;
    border-radius: var(--sn-radius-pill, 999px);
    transition: all 0.25s ease;
    color: var(--sn-color-text-muted, #8b9ba8);
    white-space: nowrap; /* Prevent multi-word wrapping */
  }

  .sn-sec-header--cinematic .sn-sec__nav-link:hover {
    color: var(--sn-color-text, #e8edf2);
    background: rgba(255, 255, 255, 0.05);
  }

  .sn-sec-header--cinematic .sn-sec__nav-link[aria-current='page'] {
    background: var(--sn-color-accent, #3a8ecf);
    color: var(--sn-color-accent-contrast, #ffffff);
    text-decoration: none;
  }

  .sn-sec-header__actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .sn-sec-header__phone {
    display: none;
    font-size: 0.9375rem;
  }

  .sn-sec-header__quote {
    display: none;
  }

  .sn-sec-header__nav {
    display: none;
  }

  /* Hamburger Button */
  .sn-sec-header__menu-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    min-height: 2.75rem;
    min-width: 2.75rem;
    padding: 0.5rem 0.85rem;
    border: 1px solid var(--sn-color-border, #d9e2ec);
    border-radius: var(--sn-radius-md, 0.5rem);
    background: var(--sn-color-surface-elevated, var(--sn-color-surface, #fff));
    color: var(--sn-color-text);
    font: inherit;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .sn-sec-header__menu-button:hover {
    background: var(--sn-color-surface-elevated);
    border-color: var(--sn-color-accent);
  }

  .sn-sec-header__menu-icon {
    width: 1.125rem;
    height: 2px;
    background: currentColor;
    box-shadow:
      0 -6px 0 currentColor,
      0 6px 0 currentColor;
    transition: transform 0.2s ease;
  }

  .sn-sec-header__menu-button[aria-expanded='true'] .sn-sec-header__menu-icon {
    background: transparent;
    box-shadow: none;
    transform: rotate(45deg);
  }
  .sn-sec-header__menu-button[aria-expanded='true'] .sn-sec-header__menu-icon::before {
    content: '';
    position: absolute;
    width: 1.125rem;
    height: 2px;
    background: currentColor;
    transform: translateY(0);
  }
  .sn-sec-header__menu-button[aria-expanded='true'] .sn-sec-header__menu-icon::after {
    content: '';
    position: absolute;
    width: 1.125rem;
    height: 2px;
    background: currentColor;
    transform: rotate(-90deg) translateY(0);
  }

  /* Slide-in Mobile Panel */
  .sn-sec-header__mobile-panel {
    position: fixed;
    inset: 0;
    z-index: 60;
    background: var(--sn-color-surface, #fff);
    padding: calc(5rem + env(safe-area-inset-top)) 1.5rem 2rem;
    overflow-y: auto;
    transform: translateX(100%);
    opacity: 0;
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease;
    pointer-events: none;
  }

  .sn-sec-header__mobile-panel.is-open {
    transform: translateX(0);
    opacity: 1;
    pointer-events: auto;
  }

  .sn-sec-header__mobile-list {
    list-style: none;
    margin: 0 0 2rem;
    padding: 0;
    display: grid;
    gap: 0.25rem;
  }

  .sn-sec-header__mobile-link {
    display: flex;
    align-items: center;
    min-height: 3rem;
    padding: 0.75rem 0;
    font-size: 1.25rem;
    font-weight: 600;
    text-decoration: none;
    border-bottom: 1px solid var(--sn-color-border, #d9e2ec);
    transition: color 0.2s ease, border-bottom-color 0.2s ease;
  }

  .sn-sec-header__mobile-link:hover,
  .sn-sec-header__mobile-link[aria-current='page'] {
    color: var(--sn-color-accent, #2f6f4e);
    border-bottom-color: var(--sn-color-accent, #2f6f4e);
  }

  .sn-sec-header__mobile-quote {
    width: 100%;
    margin-top: 1rem;
  }

  /* Sticky Footer Action Bar on Mobile */
  .sn-sec-header__sticky-cta {
    position: fixed;
    left: 1.5rem;
    right: 1.5rem;
    bottom: calc(1.5rem + env(safe-area-inset-bottom));
    z-index: 40;
    box-shadow: var(--sn-shadow-lg, 0 8px 30px rgb(0 0 0 / 18%));
    display: flex;
    justify-content: center;
    border-radius: var(--sn-radius-pill, 999px);
  }

  .sn-sec-header__sticky-cta .sn-btn {
    width: 100%;
    max-width: 28rem;
    box-shadow: none;
  }

  @media (min-width: 68rem) {
    .sn-sec-header__nav {
      display: block;
    }

    .sn-sec-header__menu-button {
      display: none;
    }

    .sn-sec-header__quote {
      display: inline-flex;
    }

    .sn-sec-header__phone {
      display: inline-flex;
    }

    .sn-sec-header__sticky-cta {
      display: none;
    }
  }
</style>