---
import Container from '@supernova/ui-primitives/Container.astro';
import Section from '@supernova/ui-primitives/Section.astro';
import Heading from '@supernova/ui-primitives/Heading.astro';

interface WhyItem {
  title: string;
  description: string;
}

interface Props {
  heading?: string;
  intro?: string;
  items: WhyItem[];
  variant?: 'editorial' | 'cinematic';
  class?: string;
}

const {
  heading = 'Why homeowners choose us',
  intro,
  items,
  variant = 'editorial',
  class: className = '',
} = Astro.props;
---

<Section class={`sn-sec-why sn-sec-why--${variant} ${className}`.trim()} ariaLabel={heading}>
  <Container>
    <div class="sn-sec-why__header">
      <Heading level={2}>{heading}</Heading>
      {intro ? <p class="sn-sec__intro">{intro}</p> : null}
    </div>

    <div class="sn-sec-why__grid">
      {
        items.map((item) => (
          <article class="sn-sec-why__item">
            <Heading level={3}>{item.title}</Heading>
            <p>{item.description}</p>
          </article>
        ))
      }
    </div>
  </Container>
</Section>

<style>
  .sn-sec-why--cinematic {
    background: var(--sn-color-surface, #1a2229);
  }

  .sn-sec-why__header {
    margin-bottom: var(--sn-space-lg, 1.5rem);
  }

  .sn-sec-why__grid {
    display: grid;
    gap: var(--sn-space-md, 1rem);
  }

  @media (min-width: 48rem) {
    .sn-sec-why--editorial .sn-sec-why__grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .sn-sec-why--cinematic .sn-sec-why__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .sn-sec-why__item {
    padding: var(--sn-space-lg, 1.5rem);
    border-radius: var(--sn-radius-lg, 1rem);
    background: var(--sn-color-surface-elevated, var(--sn-color-surface, #fff));
    border: 1px solid var(--sn-color-border, #d9e2ec);
  }

  .sn-sec-why--editorial .sn-sec-why__item {
    border-radius: var(--sn-radius-xl, 1.75rem);
  }

  .sn-sec-why__item p {
    margin: 0.5rem 0 0;
    color: var(--sn-color-text-muted, inherit);
    font-size: 0.9375rem;
    line-height: 1.55;
  }
</style>