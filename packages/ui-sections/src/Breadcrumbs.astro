---
import Container from '@supernova/ui-primitives/Container.astro';
import type { BreadcrumbsProps } from './component-props';
import { validateBreadcrumbTrail } from './props';

interface Props extends BreadcrumbsProps {}

const { items, ariaLabel = 'Breadcrumb', class: className = '' } = Astro.props;

const trail = validateBreadcrumbTrail(items);
---

<nav class={`sn-sec-breadcrumbs ${className}`.trim()} aria-label={ariaLabel}>
  <Container>
    <ol class="sn-sec-breadcrumbs__list">
      {
        trail.map((item, index) => {
          const isCurrent = index === trail.length - 1;

          return (
            <li class="sn-sec-breadcrumbs__item">
              {isCurrent || !item.href ? (
                <span aria-current={isCurrent ? 'page' : undefined}>{item.label}</span>
              ) : (
                <a class="sn-sec__breadcrumb-link" href={item.href}>
                  {item.label}
                </a>
              )}
            </li>
          );
        })
      }
    </ol>
  </Container>
</nav>

<style>
  .sn-sec-breadcrumbs {
    padding-block: var(--sn-space-sm, 0.75rem);
    font-size: 0.95rem;
  }

  .sn-sec-breadcrumbs__list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .sn-sec-breadcrumbs__item:not(:last-child)::after {
    content: '/';
    margin-left: 0.35rem;
    color: color-mix(in srgb, var(--sn-color-text, #1f2933) 50%, transparent);
  }

  .sn-sec__breadcrumb-link {
    text-decoration: none;
    font-weight: 600;
  }
</style>