---
import Container from '@supernova/ui-primitives/Container.astro';
import Section from '@supernova/ui-primitives/Section.astro';
import type { SiteFooterProps } from './component-props';
import { normalizeNavigationItems } from './props';

interface Props extends SiteFooterProps {}

const {
  navItems = [],
  copyrightLabel,
  tagline,
  disclaimer = 'Fictional demonstration business — not a real company.',
  variant = 'light',
  class: className = '',
} = Astro.props;

const links = normalizeNavigationItems(navItems);
---

<footer class={`sn-sec-footer sn-sec-footer--${variant} ${className}`.trim()}>
  <Container>
    <div class="sn-sec-footer__grid">
      <div class="sn-sec-footer__brand">
        {tagline ? <p class="sn-sec-footer__tagline">{tagline}</p> : null}
        <p class="sn-sec-footer__disclaimer" role="note">{disclaimer}</p>
      </div>

      {
        links.length > 0 ? (
          <nav class="sn-sec-footer__nav" aria-label="Footer">
            <ul class="sn-sec-footer__links">
              {links.map((item) => (
                <li>
                  <a class="sn-sec__footer-link" href={item.href}>
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        ) : null
      }
    </div>

    <p class="sn-sec-footer__copyright">{copyrightLabel}</p>
  </Container>
</footer>

<style>
  .sn-sec-footer {
    border-top: 1px solid var(--sn-color-border, #d9e2ec);
    background: var(--sn-color-surface, #ffffff);
    padding-block: clamp(2rem, 4vw, 3rem);
    padding-bottom: calc(clamp(2rem, 4vw, 3rem) + env(safe-area-inset-bottom));
  }

  .sn-sec-footer--dark {
    background: var(--sn-color-surface, #1a2229);
    color: var(--sn-color-text, #e8edf2);
  }

  .sn-sec-footer__grid {
    display: grid;
    gap: var(--sn-space-lg, 1.5rem);
    margin-bottom: var(--sn-space-lg, 1.5rem);
  }

  @media (min-width: 48rem) {
    .sn-sec-footer__grid {
      grid-template-columns: 1.2fr 0.8fr;
      align-items: start;
    }
  }

  .sn-sec-footer__tagline {
    margin: 0 0 0.75rem;
    max-width: 42ch;
    font-family: var(--sn-font-display, inherit);
    font-size: 1.125rem;
    font-weight: 600;
  }

  .sn-sec-footer__disclaimer {
    margin: 0;
    font-size: 0.875rem;
    color: var(--sn-color-text-muted, inherit);
  }

  .sn-sec-footer__links {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.5rem 1rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .sn-sec__footer-link {
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9375rem;
    padding: 0.25rem 0;
  }

  .sn-sec__footer-link:hover {
    color: var(--sn-color-accent, #2f6f4e);
  }

  .sn-sec-footer__copyright {
    margin: 0;
    padding-top: var(--sn-space-md, 1rem);
    border-top: 1px solid var(--sn-color-border, #d9e2ec);
    font-size: 0.875rem;
    color: var(--sn-color-text-muted, inherit);
  }
</style>